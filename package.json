{
  "name": "sistema-autenticacion-hardened",
  "version": "1.1.0",
  "description": "Sistema de autenticación hardened con Argon2, JWT en cookies seguras, MFA/2FA TOTP, rate limiting y security headers.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "smoke": "node scripts/smoke-test.js",
    "health:ready": "node -e \"fetch('http://localhost:3000/api/health/ready').then(r=>r.json()).then(j=>{if(!j.ok)process.exit(1);console.log('ready ok')}).catch(()=>process.exit(1))\""
  },
  "keywords": [
    "auth",
    "security",
    "argon2",
    "express",
    "jwt",
    "mfa",
    "rate-limiting",
    "helmet",
    "sprint-5"
  ],
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
