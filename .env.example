PORT=3000
NODE_ENV=development
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=15m
JWT_ISSUER=hardened-auth
JWT_AUDIENCE=hardened-auth-client
TEMP_JWT_AUDIENCE=hardened-auth-2fa
TEMP_TOKEN_EXPIRES_IN=5m
AUTH_COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
MFA_ISSUER=hardened-auth

# Sprint 5: Refresh tokens
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_JWT_AUDIENCE=hardened-auth-refresh
REFRESH_COOKIE_NAME=refresh_token

# Sprint 5: Rate limiting (ms)
LOGIN_RATE_LIMIT_WINDOW=900000
LOGIN_RATE_LIMIT_MAX=5
ACCOUNT_LOCKOUT_THRESHOLD=10
ACCOUNT_LOCKOUT_DURATION=1800000

# Sprint 5: Audit logging
ENABLE_AUDIT_LOG=true
LOG_EVENTS_FILE=data/auth-events.jsonl
